{
  "name": "@codegrenade/naija-faker-mcp",
  "version": "1.0.0",
  "description": "A naija-faker MCP server",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "inspector": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "bin": {
    "naija-faker-mcp": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "keywords": [
    "mcp-server",
    "model-context-protocol",
    "mcp",
    "naija-faker",
    "faker",
    "faker-mcp-server",
    "naija-faker-mcp-server"
  ],
  "author": "Temitope Ayotunde",
  "license": "MIT",
  "homepage": "https://github.com/kodegrenade/naija-faker-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/kodegrenade/naija-faker-mcp"
  },
  "dependencies": {
    "@codegrenade/naija-faker": "^1.0.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^25.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
